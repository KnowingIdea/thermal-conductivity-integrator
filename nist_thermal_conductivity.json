  "notes": "NIST TRC cryogenic thermal-conductivity curve fits. T in kelvin, k in W/(m-K). 'coefficients' is the list [a, b, c, ...] in letter order; letters beyond the list are zero. 'equation_type' keys into 'equation_forms'. Percent error is curve fit % error relative to data. Fits are only valid inside equation_range_K. Shorthand keys use chemical/materials-notation capitalization (element symbols where applicable: Pb=lead, Mo=molybdenum, Pt=platinum, BeCu=beryllium copper, FeNi#=iron-nickel wt%; polymer acronyms PTFE/PET/PI/PA/PVC/PS/PU).",
  "equation_forms": {
    "log10_polynomial": {
      "equation": "k = 10^(a + b*log10(T) + c*log10(T)^2 + d*log10(T)^3 + e*log10(T)^4 + f*log10(T)^5 + g*log10(T)^6 + h*log10(T)^7 + i*log10(T)^8)",
      "description": "Base-10 log polynomial: log10(k) is a polynomial in log10(T). T in kelvin, k in W/(m-K)."
    },
    "rational_sqrtT": {
      "equation": "k = 10^((a + c*T^0.5 + e*T + g*T^1.5 + i*T^2) / (1 + b*T^0.5 + d*T + f*T^1.5 + h*T^2))",
      "description": "Rational function of sqrt(T) powers in the exponent (used for OFHC copper, one fit per RRR value). T in kelvin, k in W/(m-K)."
    }
